# ===================================
# Musashi API Environment Variables
# ===================================

# Required for Vercel KV (Redis) - used by movers endpoint
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-token

# Cron security - required for /api/cron/collect-tweets
CRON_SECRET=your-secret-key

# Twitter API - required for tweet collection
TWITTER_BEARER_TOKEN=your-twitter-token

# Optional: API authentication
API_KEY=optional-secret

# ===================================
# Cache Configuration (NEW)
# ===================================

# Market data cache TTL in seconds
# Default: 20 seconds (reduced from 5 minutes for trading)
# Recommended for production trading: 15-30 seconds
# Set higher (60-300) if you want to reduce API costs
MARKET_CACHE_TTL_SECONDS=20

# Arbitrage opportunities cache TTL in seconds
# Default: 15 seconds (reduced from 5 minutes for trading)
# Recommended for production trading: 10-20 seconds
# Arbitrage opportunities disappear quickly, keep this low
ARBITRAGE_CACHE_TTL_SECONDS=15
