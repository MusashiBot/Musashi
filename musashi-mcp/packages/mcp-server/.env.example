# Musashi MCP Server Configuration

# API Keys (Optional - Free tier available without keys)
# Format: key1:tier,key2:tier
# Tiers: free (100 req/hour) | pro (1000 req/hour)
# Example: MUSASHI_API_KEYS=abc123:pro,def456:free
MUSASHI_API_KEYS=

# Node Environment
NODE_ENV=production

# Server Configuration
# MUSASHI_CACHE_SIZE=10000
# MUSASHI_CACHE_TTL=300000
